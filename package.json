{
  "name": "gitlab-auto-deploy",
  "version": "1.0.0",
  "description": "GitLab Auto Deploy Tool",
  "main": "./out/main/index.js",
  "author": "wangzhe",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,scss,json}\"",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:all": "pnpm build && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@gitbeaker/rest": "^40.0.0",
    "axios": "^1.6.0",
    "electron-log": "^5.0.0",
    "element-plus": "^2.13.0",
    "execa": "^5.1.1",
    "fs-extra": "^11.2.0",
    "pinia": "^2.1.0",
    "ssh2": "^1.15.0",
    "vue": "^3.5.0",
    "vue-router": "^5.0.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/notarize": "^2.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.69.0",
    "typescript": "^5.9.0",
    "vite": "^5.0.0"
  }
}